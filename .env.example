# Example environment variables for local development and Render
# Replace the values with your production credentials in Render settings

# PostgreSQL connection URL (required)
# Example: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# Secret key for JWT signing (required in production)
SECRET_KEY=

# If your hosting requires SSL for the DB connection, set to 'true'
DATABASE_SSL=true

# Application port (Render sets this automatically)
PORT=

# Set NODE_ENV=production on Render
NODE_ENV=production
